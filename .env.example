# Frazer CRM Integration
# Set this to your Frazer inventory feed URL to pull live inventory data.
# Without this, the site will display sample inventory data.
#
# Examples:
# FRAZER_FEED_URL=https://www.frazer.com/feed/yourdealercode/inventory.xml
# FRAZER_FEED_URL=https://yourserver.com/frazer-export/inventory.json
FRAZER_FEED_URL=
