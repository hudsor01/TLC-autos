generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── INVENTORY ───

model Vehicle {
  id              String   @id @default(cuid())
  stockNumber     String   @unique
  vin             String
  year            Int
  make            String
  model           String
  trim            String   @default("")
  bodyStyle       String   @default("")
  exteriorColor   String   @default("")
  interiorColor   String   @default("")
  mileage         Int      @default(0)
  mileageType     String   @default("Actual")
  fuelType        String   @default("Gasoline")
  transmission    String   @default("")
  engine          String   @default("")
  cylinders       Int?
  drivetrain      String   @default("")
  vehicleType     String   @default("")
  description     String   @default("")
  features        String   @default("[]")
  status          String   @default("available")

  purchasePrice   Float    @default(0)
  buyerFee        Float    @default(0)
  lotFee          Float    @default(0)
  addedCosts      Float    @default(0)
  totalCost       Float    @default(0)
  sellingPrice    Float    @default(0)

  purchaseDate    DateTime @default(now())
  dateAdded       DateTime @default(now())
  dateSold        DateTime?
  locationCode    String   @default("")
  gpsSerial       String   @default("")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  images          VehicleImage[]
  costItems       VehicleCost[]
  deals           Deal[]
}

model VehicleImage {
  id        String  @id @default(cuid())
  url       String
  alt       String  @default("")
  isPrimary Boolean @default(false)
  order     Int     @default(0)
  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model VehicleCost {
  id          String   @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  description String
  amount      Float
  vendor      String   @default("")
  date        DateTime @default(now())
  category    String   @default("repair")
  createdAt   DateTime @default(now())
}

// ─── CUSTOMERS & LEADS ───

model Customer {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String
  email          String   @default("")
  phone          String   @default("")
  address        String   @default("")
  city           String   @default("")
  state          String   @default("")
  zip            String   @default("")
  driversLicense String   @default("")
  notes          String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  deals          Deal[]
  leads          Lead[]
}

model Lead {
  id              String    @id @default(cuid())
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id])

  firstName       String    @default("")
  lastName        String    @default("")
  email           String    @default("")
  phone           String    @default("")

  source          String    @default("website")
  status          String    @default("new")
  vehicleInterest String    @default("")
  tradeVehicle    String    @default("")
  notes           String    @default("")
  assignedTo      String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  followUps       FollowUp[]
}

model FollowUp {
  id        String    @id @default(cuid())
  leadId    String
  lead      Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      String    @default("note")
  content   String
  dueDate   DateTime?
  completed Boolean   @default(false)
  createdBy String
  createdAt DateTime  @default(now())
}

// ─── SALES / DESKING ───

model Deal {
  id              String   @id @default(cuid())
  dealNumber      String   @unique
  vehicleId       String
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id])
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id])

  saleType        String   @default("cash")
  status          String   @default("pending")

  sellingPrice    Float    @default(0)
  tradeAllowance  Float    @default(0)
  tradePayoff     Float    @default(0)
  downPayment     Float    @default(0)
  taxRate         Float    @default(6.25)
  taxAmount       Float    @default(0)
  titleFee        Float    @default(0)
  registrationFee Float    @default(0)
  docFee          Float    @default(0)
  otherFees       Float    @default(0)
  totalPrice      Float    @default(0)

  amountFinanced  Float    @default(0)
  apr             Float    @default(0)
  term            Int      @default(0)
  monthlyPayment  Float    @default(0)
  lienHolder      String   @default("")

  salesperson     String   @default("")
  saleDate        DateTime @default(now())
  notes           String   @default("")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── USERS ───

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("staff")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
